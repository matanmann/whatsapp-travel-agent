NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Railway / Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/travel_agent?schema=public"

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI Provider (Anthropic compatible)
AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-20250514
AI_BASE_URL=https://api.anthropic.com/v1

# Security
DASHBOARD_API_KEY=replace-with-long-random-secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
MAX_MESSAGE_LENGTH=2000
BLOCK_PROMPT_INJECTION=true
ALLOWED_PHONES=

# Reminder cron (UTC)
REMINDER_CRON=*/10 * * * *

# Frontend simulator (Vite)
VITE_API_BASE_URL=http://localhost:3000
